{
    "name": "greenstep/api",
    "description": "GreenStep Carbon Footprint Tracker - RESTful API Backend",
    "type": "project",
    "require": {
        "php": "^8.0",
        "firebase/php-jwt": "*",
        "php-di/php-di": "^7.0",
        "slim/psr7": "*",
        "slim/slim": "*",
        "vlucas/phpdotenv": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Config\\": "config/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "policy": {
            "advisories": {
                "block": false,
                "ignore-id": ["PKSA-y2cr-5h3j-g3ys"]
            }
        }
    },
    "extra": {
        "composer": {
            "ignore": "PKSA-y2cr-5h3j-g3ys"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:${PORT:-8080} -t public"
    }
}

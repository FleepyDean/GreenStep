# Backend Production Environment (Railway)
# Copy to api/.env and fill with your Railway MySQL credentials

# Database Configuration
DB_HOST=roundhouse.proxy.rlwy.net
DB_PORT=3306
DB_NAME=railway
DB_USER=root
DB_PASS=your-railway-mysql-password

# JWT Configuration
JWT_SECRET=your-production-jwt-secret
JWT_EXPIRY=86400

# CORS — Railway frontend URL
FRONTEND_URL=https://greenstep.up.railway.app

# Application
APP_ENV=production
APP_DEBUG=false

# Server port (Railway assigns this)
PORT=8080
